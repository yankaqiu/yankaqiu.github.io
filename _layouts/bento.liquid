<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <!-- Header -->
    {% include header.liquid %}

    <!-- Bento Grid — NO .container wrapper, full viewport -->
    <div class="bento-container" id="bento-container">

      <!-- ===== TOP SECTION (Hero | Research) ===== -->
      <div class="bento-top" id="bento-top">
        <!-- Hero -->
        <div class="bento-panel bento-hero" id="panel-hero">
          <div class="bento-panel-inner" data-animate="content">
            <p class="bento-greeting">Hi, I am</p>
            <h1 class="bento-name">
              {% if site.title == 'blank' %}
                <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }} {{ site.last_name }}
              {% else %}
                {{ site.title }}
              {% endif %}
            </h1>
            {% if page.taglines %}
              <div class="bento-taglines" id="bento-taglines">
                {% for line in page.taglines %}
                  <span class="bento-tagline">{{ line }}</span>
                {% endfor %}
              </div>
            {% endif %}
            {% if page.phd_seeking %}
              <div class="bento-phd-badge">
                <span>🎓 {{ page.phd_seeking.title }}</span>
              </div>
            {% endif %}
          </div>
        </div>

        <!-- Top Vertical Divider -->
        <div class="bento-divider bento-divider-v" id="div-top-v" data-divider="vertical-top">
          <div class="bento-divider-line" data-animate="line-v"></div>
        </div>

        <!-- Research -->
        {% if page.research %}
        <div class="bento-panel bento-research" id="panel-research">
          <div class="bento-panel-inner" data-animate="content">
            <h3 class="bento-section-title">Research Interests</h3>
            <div class="bento-skill-list">
              {% for interest in page.research.interests %}
                <span class="bento-skill{% if page.research.highlights contains interest %} bento-skill-hl{% endif %}">{{ interest }}</span>
              {% endfor %}
            </div>
            {% if page.research.description %}
              <p class="bento-research-desc">{{ page.research.description }}</p>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>

      <!-- Main Horizontal Divider -->
      <div class="bento-divider bento-divider-h" id="div-main-h" data-divider="horizontal-main">
        <div class="bento-divider-line" data-animate="line-h"></div>
      </div>

      <!-- ===== MIDDLE SECTION (News | About) ===== -->
      <div class="bento-middle" id="bento-middle">
        <!-- News -->
        {% if page.news and site.announcements.enabled %}
        <div class="bento-panel bento-news" id="panel-news">
          <div class="bento-panel-inner" data-animate="content">
            <h3 class="bento-section-title">
              <a href="{{ '/news/' | relative_url }}">News</a>
            </h3>
            {% include news.liquid limit=true %}
          </div>
        </div>
        {% endif %}

        <!-- Middle Vertical Divider -->
        <div class="bento-divider bento-divider-v" id="div-mid-v" data-divider="vertical-middle">
          <div class="bento-divider-line" data-animate="line-v"></div>
        </div>

        <!-- About -->
        <div class="bento-panel bento-about" id="panel-about">
          <div class="bento-panel-inner" data-animate="content">
            <h3 class="bento-section-title">About Me</h3>
            <div class="bento-about-content">
              {% if page.profile.image %}
                <div class="bento-about-photo">
                  {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
                  {%
                    include figure.liquid loading="eager" path=profile_image_path class="img-fluid" alt=page.profile.image
                    cache_bust=true
                  %}
                </div>
              {% endif %}
              <div class="bento-about-text">
                {{ content }}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Second Horizontal Divider -->
      <div class="bento-divider bento-divider-h" id="div-bot-h" data-divider="horizontal-bottom">
        <div class="bento-divider-line" data-animate="line-h"></div>
      </div>

      <!-- ===== BOTTOM SECTION (Hobbies | Social) ===== -->
      <div class="bento-bottom" id="bento-bottom">
        <!-- Hobbies -->
        {% if page.hobbies %}
        <div class="bento-panel bento-hobbies" id="panel-hobbies">
          <div class="bento-panel-inner" data-animate="content">
            <h3 class="bento-section-title">Beyond Work</h3>
            <div class="bento-skill-list">
              {% for hobby in page.hobbies %}
                <span class="bento-skill">{{ hobby }}</span>
              {% endfor %}
            </div>
          </div>
        </div>
        {% endif %}

        <!-- Bottom Vertical Divider -->
        <div class="bento-divider bento-divider-v" id="div-bot-v" data-divider="vertical-bottom">
          <div class="bento-divider-line" data-animate="line-v"></div>
        </div>

        <!-- Social -->
        {% if page.social %}
        <div class="bento-panel bento-social" id="panel-social">
          <div class="bento-panel-inner" data-animate="content">
            <h3 class="bento-section-title">Get in Touch</h3>
            <div class="contact-icons">{% include social.liquid %}</div>
          </div>
        </div>
        {% endif %}
      </div>

    </div>

    <!-- JavaScripts -->
    {% include scripts.liquid %}
    <script src="{{ '/assets/js/bento.js' | relative_url }}"></script>
  </body>
</html>
